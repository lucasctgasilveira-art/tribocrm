# Ambiente de desenvolvimento — copie para .env.local e ajuste conforme necessário

# URL da API do TriboCRM
# Em dev: http://localhost:3000
# Em staging: https://api-staging.tribocrm.com.br
# Em prod: https://api.tribocrm.com.br
VITE_API_BASE_URL=http://localhost:3000

# Liga os mocks (true = não chama API real, usa dados fake)
# Use enquanto o backend ainda não está pronto
VITE_USE_MOCKS=true

# URL do app web (usado em links do tipo "abrir no CRM")
VITE_WEB_APP_URL=http://localhost:5174
