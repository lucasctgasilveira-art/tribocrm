{
  "name": "tribocrm-extension",
  "version": "0.1.0",
  "description": "Extensão do Chrome do TriboCRM — painel lateral no WhatsApp Web, captura no LinkedIn e Gmail",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build --mode production",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "zip": "cd dist && zip -r ../tribocrm-extension.zip ."
  },
  "dependencies": {
    "htm": "^3.1.1",
    "preact": "^10.22.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
