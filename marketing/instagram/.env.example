# =============================================================
# TriboCRM · Instagram Pipeline · Template de variáveis
# =============================================================
# Copie este arquivo pra .env e preencha com os valores reais.
# .env é local e não vai pro git.
# =============================================================

# --- Cloudinary ---
# Pega no Dashboard Cloudinary → Settings → API Keys
CLOUDINARY_CLOUD_NAME=seu-cloud-name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=sua-api-secret-aqui

# --- Instagram Graph API (Meta for Developers) ---
# App: Meta for Developers → Configurações do app → Básico
IG_APP_ID=000000000000000
IG_APP_SECRET=sua-app-secret-aqui

# Token long-lived (60 dias) gerado no use case "Gerenciar mensagens e conteúdo no Instagram"
IG_LONG_LIVED_TOKEN=EAAxxx...

# IG Business Account ID — aparece no painel do use case Instagram (linha do @handle)
IG_BUSINESS_ACCOUNT_ID=00000000000000000

# Handle pra logs/notificações (opcional)
INSTAGRAM_HANDLE=@seuhandle

# --- Discord webhook (notificações de publicação) ---
# Discord → canal → engrenagem → Integrações → Webhooks → Copiar URL
# Deixe vazio se não usar — publish.mjs apenas pula a notificação.
DISCORD_WEBHOOK_URL=