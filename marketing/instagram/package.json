{
  "name": "@tribocrm/instagram-pipeline",
  "version": "0.1.0",
  "description": "Pipeline de automação de peças estáticas pro Instagram do TriboCRM — pauta YAML → HTML → PNG via Puppeteer",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "post": "node scripts/render-post.mjs",
    "posts:all": "node scripts/render-batch.mjs",
    "upload": "node scripts/upload-cloudinary.mjs",
    "publish": "node scripts/publish.mjs",
    "validate": "node scripts/validate-publishing.mjs",
    "refresh-token": "node scripts/refresh-token.mjs"
  },
  "dependencies": {
    "cloudinary": "^2.5.0",
    "dotenv": "^16.4.0",
    "js-yaml": "^4.1.0",
    "puppeteer": "^23.0.0"
  }
}
