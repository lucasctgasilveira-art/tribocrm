# Banco de dados (Supabase PostgreSQL)
DATABASE_URL=
DIRECT_URL=

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=

# Servidor
NODE_ENV=production
PORT=3002
FRONTEND_URL=https://tribocrm.vercel.app

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Banco EFI (pagamentos)
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_SANDBOX=false

# Secret para validar webhooks do Efi (gerado via crypto.randomBytes(32))
# Usado no registro da URL: ?hmac=<EFI_WEBHOOK_HMAC>&ignorar=
EFI_WEBHOOK_HMAC=

# URL completa do webhook (com hmac e ignorar) registrada na Efi
# Exemplo: https://api.tribocrm.com.br/webhooks/efi?hmac=<hash>&ignorar=
EFI_WEBHOOK_URL=

# Chave PIX da conta Efi usada pra registrar o webhook
EFI_PIX_KEY=

# SMTP (e-mail de sistema — boas-vindas, alertas de expiração, etc.)
# Se não configurado, e-mails são silenciosamente ignorados e o sistema
# funciona normalmente — o gestor vê as senhas temporárias via UI.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TriboCRM <noreply@seudominio.com.br>

# Supabase (opcional — storage/realtime)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Sentry monitoramento (opcional em dev, obrigatório em produção)
# Obter DSN em https://tribocrm.sentry.io/projects/tribocrm-backend/
SENTRY_DSN=
