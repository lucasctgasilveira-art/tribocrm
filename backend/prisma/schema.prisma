model CaptureForm {
  id                    String           @id @default(uuid()) @db.Uuid
  tenantId              String           @map("tenant_id") @db.Uuid
  name                  String           @db.VarChar(100)
  fieldsConfig          Json             @map("fields_config")
  destinationPipelineId String           @map("destination_pipeline_id") @db.Uuid
  destinationStageId    String           @map("destination_stage_id") @db.Uuid
  distributionType      DistributionType @map("distribution_type")
  automationId          String?          @map("automation_id") @db.Uuid
  embedToken            String           @unique @map("embed_token") @db.VarChar(100)
  isActive              Boolean          @default(true) @map("is_active")
  successRedirectUrl    String?          @map("success_redirect_url") @db.VarChar(500)
  successMessage        String?          @map("success_message") @db.VarChar(300)
  createdAt             DateTime         @default(now()) @map("created_at")
  tenant                Tenant           @relation(fields: [tenantId], references: [id])
  submissions           FormSubmission[]
  @@map("capture_forms")
}

model FormSubmission {
  id          String               @id @default(uuid()) @db.Uuid
  tenantId    String               @map("tenant_id") @db.Uuid
  formId      String               @map("form_id") @db.Uuid
  leadId      String?              @map("lead_id") @db.Uuid
  rawData     Json                 @map("raw_data")
  status      FormSubmissionStatus @default(PROCESSED)
  ipAddress   String?              @map("ip_address") @db.VarChar(50)
  submittedAt DateTime             @default(now()) @map("submitted_at")
  form        CaptureForm          @relation(fields: [formId], references: [id])
  @@map("form_submissions")
}

model Goal {
  id               String               @id @default(uuid()) @db.Uuid
  tenantId         String               @map("tenant_id") @db.Uuid
  pipelineId       String               @map("pipeline_id") @db.Uuid
  periodType       GoalPeriodType       @map("period_type")
  periodReference  String               @map("period_reference") @db.VarChar(10)
  goalType         GoalType             @map("goal_type")
  totalRevenueGoal Decimal?             @map("total_revenue_goal") @db.Decimal(12, 2)
  totalDealsGoal   Int?                 @map("total_deals_goal")
  distributionType GoalDistributionType @map("distribution_type")
  createdBy        String               @map("created_by") @db.Uuid
  createdAt        DateTime             @default(now()) @map("created_at")
  tenant           Tenant               @relation(fields: [tenantId], references: [id])
  pipeline         Pipeline             @relation(fields: [pipelineId], references: [id])
  individualGoals  GoalIndividual[]
  @@map("goals")
}

model GoalIndividual {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  goalId      String   @map("goal_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  revenueGoal Decimal? @map("revenue_goal") @db.Decimal(12, 2)
  dealsGoal   Int?     @map("deals_goal")
  isRamping   Boolean  @default(false) @map("is_ramping")
  createdAt   DateTime @default(now()) @map("created_at")
  goal        Goal     @relation(fields: [goalId], references: [id])
  @@unique([goalId, userId])
  @@map("goal_individual")
}

model Product {
  id               String                @id @default(uuid()) @db.Uuid
  tenantId         String                @map("tenant_id") @db.Uuid
  name             String                @db.VarChar(150)
  description      String?               @db.Text
  category         String?               @db.VarChar(80)
  price            Decimal               @db.Decimal(12, 2)
  allowsDiscount   Boolean               @default(false) @map("allows_discount")
  discountType     DiscountType?         @map("discount_type")
  maxDiscount      Decimal?              @map("max_discount") @db.Decimal(10, 2)
  approvalType     DiscountApprovalType? @map("approval_type")
  isActive         Boolean               @default(true) @map("is_active")
  createdAt        DateTime              @default(now()) @map("created_at")
  tenant           Tenant                @relation(fields: [tenantId], references: [id])
  leadProducts     LeadProduct[]
  discountRequests DiscountRequest[]
  @@map("products")
}

model DiscountRequest {
  id                String                 @id @default(uuid()) @db.Uuid
  tenantId          String                 @map("tenant_id") @db.Uuid
  leadId            String                 @map("lead_id") @db.Uuid
  productId         String                 @map("product_id") @db.Uuid
  requestedBy       String                 @map("requested_by") @db.Uuid
  approvedBy        String?                @map("approved_by") @db.Uuid
  requestedDiscount Decimal                @map("requested_discount") @db.Decimal(10, 2)
  discountType      DiscountType           @map("discount_type")
  status            DiscountApprovalStatus @default(PENDING)
  rejectionReason   String?                @map("rejection_reason") @db.Text
  resolvedAt        DateTime?              @map("resolved_at")
  createdAt         DateTime               @default(now()) @map("created_at")
  product           Product                @relation(fields: [productId], references: [id])
  @@map("discount_requests")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(150)
  body      String           @db.Text
  link      String?          @db.VarChar(500)
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation(fields: [userId], references: [id])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address") @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at")
  @@map("audit_logs")
}

// Persistent log of every transactional/system email attempt
// (sub-etapa 6L.1.a). Populated by mailer.service fire-and-forget
// after each Brevo call — failure to write here never blocks the
// email itself. Surfaces in /admin UI for ops debugging.
model EmailLog {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String?  @map("tenant_id") @db.Uuid
  toEmail         String   @map("to_email") @db.VarChar(255)
  templateId      Int?     @map("template_id")
  subject         String?  @db.VarChar(255)
  status          String   @db.VarChar(30)
  brevoMessageId  String?  @map("brevo_message_id") @db.VarChar(150)
  errorReason     String?  @map("error_reason") @db.VarChar(50)
  errorDetails    String?  @map("error_details") @db.Text
  paramsJson      Json?    @map("params_json")
  sentAt          DateTime @default(now()) @map("sent_at")

  @@index([tenantId, sentAt(sort: Desc)])
  @@index([status, sentAt(sort: Desc)])
  @@map("email_logs")
}

// Background-processed email campaigns (sub-etapa 6L.3.a). Created
// in PENDING by POST /admin/campaign/send, picked up by the
// campaign-runner cron (every 1 min, 1 campaign per tick) which
// resolves recipients and loops through sendTemplateMail with rate
// limit. Frees the HTTP request from the timeout that capped the
// 6L.2 MVP at ~500 destinatários.
model EmailCampaign {
  id              String    @id @default(uuid()) @db.Uuid
  templateId      Int       @map("template_id")
  paramsJson      Json      @map("params_json")
  audience        String    @db.VarChar(20)
  filtersJson     Json      @map("filters_json")
  status          String    @db.VarChar(20)
  totalRecipients Int       @default(0) @map("total_recipients")
  sent            Int       @default(0)
  failed          Int       @default(0)
  skipped         Int       @default(0)
  errorMessage    String?   @map("error_message") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  createdBy       String?   @map("created_by") @db.Uuid

  @@index([status, createdAt(sort: Desc)])
  @@map("email_campaigns")
}

model Popup {
  id          String    @id @default(cuid())
  type        String
  instances   String[]
  plans       String[]
  message     String
  buttonLabel String?
  buttonUrl   String?
  frequency   String
  startDate   DateTime
  endDate     DateTime?
  imageUrl    String?   @db.Text
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  createdBy   String
}
