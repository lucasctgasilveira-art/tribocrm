generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AdminRole {
  SUPER_ADMIN
  FINANCIAL
  SUPPORT
  COMMERCIAL
}

enum TenantStatus {
  TRIAL
  ACTIVE
  PAYMENT_OVERDUE
  SUSPENDED
  CANCELLED
}

enum PlanCycle {
  MONTHLY
  YEARLY
}

enum ChargeStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  PIX
  BOLETO
  CREDIT_CARD
  MANUAL
}

enum PreferredPaymentMethod {
  PIX
  BOLETO
  CREDIT_CARD
}

enum UserRole {
  OWNER
  MANAGER
  TEAM_LEADER
  SELLER
}

enum LeadStatus {
  ACTIVE
  WON
  LOST
  ARCHIVED
}

enum Temperature {
  HOT
  WARM
  COLD
}

enum StageType {
  NORMAL
  WON
  LOST
  REACTIVATION
}

enum DistributionType {
  MANUAL
  ROUND_ROBIN_ALL
  ROUND_ROBIN_TEAM
  SPECIFIC_USER
}

enum InteractionType {
  CALL
  EMAIL
  MEETING
  WHATSAPP
  PROPOSAL
  VISIT
  NOTE
  SYSTEM
}

enum TaskType {
  CALL
  EMAIL
  MEETING
  WHATSAPP
  VISIT
}

enum OAuthProvider {
  GMAIL
  GOOGLE_CALENDAR
}

enum DiscountType {
  PERCENTAGE
  FIXED_VALUE
}

enum DiscountApprovalType {
  PASSWORD
  VALIDATION_QUEUE
  BOTH
}

enum DiscountApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AutomationTrigger {
  STAGE_CHANGED
  INACTIVE_DAYS
  TASK_OVERDUE
  LEAD_CREATED
  PRODUCT_ADDED
  GOAL_REACHED
  FORM_SUBMITTED
  EMAIL_OPENED
  DISCOUNT_REQUESTED
  REPEAT_PURCHASE
}

enum AutomationAction {
  SEND_WHATSAPP
  SEND_EMAIL
  CREATE_TASK
  MOVE_STAGE
  NOTIFY_USER
  DUPLICATE_LEAD
  MOVE_TO_PIPELINE
}

enum AutomationLogStatus {
  SUCCESS
  FAILED
  SKIPPED
}

enum FormSubmissionStatus {
  PROCESSED
  FAILED
  DUPLICATE
}

enum NotificationType {
  EMAIL_OPENED
  TASK_DUE
  DISCOUNT_PENDING
  WHATSAPP_FAILED
  GOAL_ALERT
  BIRTHDAY
  AUTOMATION
}

enum PopupType {
  OVERDUE
  NEWS
  PROMO
  SURVEY
  MAINTENANCE
  WELCOME
}

enum PopupTarget {
  INSTANCE_2
  INSTANCE_3
  BOTH
}

enum PopupFrequency {
  ALWAYS_LOGIN
  ONCE_PER_SESSION
  ONCE_PER_DAY
  ONCE_PER_WEEK
}

enum MenuButtonType {
  MENTORIA
  TREINAMENTOS
}

enum FieldType {
  TEXT
  NUMBER
  DATE
  SELECT
}

enum VisibilityType {
  OWN
  TEAM
  ALL
}

enum ThemePreference {
  DARK
  LIGHT
}

enum GoalPeriodType {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum GoalType {
  REVENUE
  DEALS
  BOTH
}

enum GoalDistributionType {
  GENERAL
  INDIVIDUAL
}

enum RecurrenceType {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum ScheduledMessageStatus {
  PENDING
  SENT
  FAILED
}

model AdminUser {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @db.VarChar(150)
  email            String    @unique @db.VarChar(255)
  passwordHash     String    @map("password_hash") @db.VarChar(255)
  role             AdminRole
  isActive         Boolean   @default(true) @map("is_active")
  // Grants the admin user a second identity as a tenant gestor. When
  // true, login surfaces a "Como deseja entrar?" selector between
  // /admin and /gestao. Toggled via PATCH /admin/users/:id/dual-access
  // by another admin that already has isDualAccess=true (password
  // confirmation required).
  isDualAccess     Boolean   @default(false) @map("is_dual_access")
  // Optional tenant this admin is linked to when operating as a
  // gestor through the dual-access flow. The auth middleware reads
  // this from the JWT on every non-/admin request and rewrites
  // req.user.tenantId so downstream controllers query the linked
  // tenant's data instead of the platform sentinel. Raw UUID with
  // no @relation — mirrors createdBy on ManagerialTask, which is
  // intentional (see commit rationale for avoiding a DB FK here).
  linkedTenantId   String?   @map("linked_tenant_id") @db.Uuid
  permissions      Json?     @db.JsonB
  twoFactorSecret  String?   @map("two_factor_secret") @db.VarChar(100)
  twoFactorEnabled Boolean   @default(false) @map("two_factor_enabled")
  lastLoginAt      DateTime? @map("last_login_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  @@map("admin_users")
}

model Plan {
  id                   String   @id @default(uuid()) @db.Uuid
  name                 String   @db.VarChar(50)
  slug                 String   @unique @db.VarChar(30)
  priceMonthly         Decimal  @map("price_monthly") @db.Decimal(10, 2)
  priceYearly          Decimal  @map("price_yearly") @db.Decimal(10, 2)
  maxUsers             Int      @map("max_users")
  extraUserPrice       Decimal  @map("extra_user_price") @db.Decimal(10, 2)
  maxLeads             Int      @map("max_leads")
  maxPipelines         Int      @map("max_pipelines")
  maxAutomations       Int      @map("max_automations")
  maxForms             Int      @map("max_forms")
  maxCustomFields      Int      @map("max_custom_fields")
  maxEmailTemplates    Int      @map("max_email_templates")
  maxWhatsappTemplates Int      @map("max_whatsapp_templates")
  features             Json
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  tenants              Tenant[]
  @@map("plans")
}

model GlobalPopup {
  id             String         @id @default(uuid()) @db.Uuid
  title          String         @db.VarChar(150)
  message        String         @db.Text
  type           PopupType
  targetInstance PopupTarget    @map("target_instance")
  targetPlans    String[]       @map("target_plans")
  frequency      PopupFrequency
  ctaLabel       String?        @map("cta_label") @db.VarChar(80)
  ctaUrl         String?        @map("cta_url") @db.VarChar(500)
  startsAt       DateTime       @map("starts_at")
  endsAt         DateTime?      @map("ends_at")
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at")
  @@map("global_popups")
}

model MenuButton {
  id        String         @id @default(uuid()) @db.Uuid
  type      MenuButtonType
  label     String         @db.VarChar(80)
  url       String         @db.VarChar(500)
  isActive  Boolean        @default(true) @map("is_active")
  order     Int
  updatedAt DateTime       @updatedAt @map("updated_at")
  @@map("menu_buttons")
}

model Tenant {
  id            String       @id @default(uuid()) @db.Uuid
  name          String       @db.VarChar(150)
  tradeName     String?      @map("trade_name") @db.VarChar(150)
  cnpj          String       @unique @db.VarChar(18)
  document      String?      @db.VarChar(18)
  email         String       @db.VarChar(255)
  phone         String?      @db.VarChar(20)
  planId        String       @map("plan_id") @db.Uuid
  planCycle     PlanCycle    @map("plan_cycle")
  status        TenantStatus @default(TRIAL)
  trialEndsAt   DateTime?    @map("trial_ends_at")
  planStartedAt DateTime?    @map("plan_started_at")
  planExpiresAt DateTime?    @map("plan_expires_at")
  internalNotes  String?      @map("internal_notes") @db.Text
  discountType   String?      @map("discount_type") @db.VarChar(20)
  discountValue  Decimal?     @map("discount_value") @db.Decimal(10, 2)
  discountFrom   DateTime?    @map("discount_from")
  discountUntil  DateTime?    @map("discount_until")
  discountCycles Int?         @map("discount_cycles")
  discountReason String?      @map("discount_reason") @db.Text
  site                String?  @db.VarChar(255)
  responsibleName     String?  @map("responsible_name") @db.VarChar(150)
  foundedAt           DateTime? @map("founded_at") @db.Date
  addressStreet       String?  @map("address_street") @db.VarChar(255)
  addressNumber       String?  @map("address_number") @db.VarChar(20)
  addressComplement   String?  @map("address_complement") @db.VarChar(150)
  addressNeighborhood String?  @map("address_neighborhood") @db.VarChar(150)
  addressCity         String?  @map("address_city") @db.VarChar(150)
  addressState        String?  @map("address_state") @db.VarChar(2)
  addressZip          String?  @map("address_zip") @db.VarChar(10)
  preferredPaymentMethod PreferredPaymentMethod? @map("preferred_payment_method")
  // Billing state machine (sub-etapa 6A). Last known state for
  // idempotency of the pre-billing / overdue / suspension jobs — each
  // job checks (lastBillingState, lastBillingStateAt) before acting so
  // re-runs on the same day become no-ops. Null means "never evaluated".
  lastBillingState   String?   @map("last_billing_state")
  lastBillingStateAt DateTime? @map("last_billing_state_at")
  // Card subscription (sub-etapa 6J). Populated on successful
  // /payments/card-subscription; null for PIX/Boleto customers who
  // never opted into recurring billing.
  efiSubscriptionId     String?   @map("efi_subscription_id") @db.VarChar(100)
  efiSubscriptionStatus String?   @map("efi_subscription_status") @db.VarChar(20)
  cardLastFour          String?   @map("card_last_four") @db.VarChar(4)
  cardBrand             String?   @map("card_brand") @db.VarChar(20)
  cardExpiresAt         DateTime? @map("card_expires_at") @db.Date
  nextBillingAt         DateTime? @map("next_billing_at")
  termsAcceptedAt    DateTime? @map("terms_accepted_at")
  termsVersion       String?   @map("terms_version") @db.VarChar(10)
  privacyAcceptedAt  DateTime? @map("privacy_accepted_at")
  privacyVersion     String?   @map("privacy_version") @db.VarChar(10)
  // First-access onboarding wizard state — surfaced to the gestor via
  // PATCH /tenants/onboarding and read on login. Only used by the
  // MANAGER/OWNER-facing OnboardingWizard overlay.
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  onboardingStep      Int      @default(0) @map("onboarding_step")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  plan           Plan         @relation(fields: [planId], references: [id])
  users          User[]
  teams          Team[]
  pipelines      Pipeline[]
  leads          Lead[]
  charges        Charge[]
  automations      Automation[]
  automationEvents AutomationEvent[]
  captureForms     CaptureForm[]
  products       Product[]
  goals          Goal[]
  notes          TenantNote[]
  leadPurchases  LeadPurchase[]
  apiKeys        ApiKey[]
  webhookEndpoints WebhookEndpoint[]
  partnerCommissions  PartnerCommission[]  @relation("CommissionsForTenant")
  partnerChanges      TenantPartnerChange[] @relation("PartnerChangesForTenant")
  // Programa de parceiros — quem indicou esse tenant.
  // Setado no signup (via cookie ?ref=) ou via UI do gestor depois.
  // Se cliente trocar de parceiro, esse campo é sobrescrito e o
  // histórico fica em TenantPartnerChange. NULL = veio direto.
  referredByPartnerId String?  @map("referred_by_partner_id") @db.Uuid
  referredAt          DateTime? @map("referred_at")
  referredBy          Partner? @relation("TenantReferredByPartner", fields: [referredByPartnerId], references: [id], onDelete: SetNull)
  @@map("tenants")
}

model TenantNote {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  content   String   @db.Text
  author    String   @db.VarChar(150)
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  @@map("tenant_notes")
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique @db.VarChar(20)
  description     String?   @db.Text
  discountType    String    @map("discount_type") @db.VarChar(10)
  discountValue   Decimal   @map("discount_value") @db.Decimal(10, 2)
  applicablePlans String[]  @map("applicable_plans")
  maxUses         Int?      @map("max_uses")
  maxUsesPerUser  Int       @default(1) @map("max_uses_per_user")
  usedCount       Int       @default(0) @map("used_count")
  validFrom       DateTime  @default(now()) @map("valid_from")
  validUntil      DateTime? @map("valid_until")
  durationType    String    @default("FIRST") @map("duration_type") @db.VarChar(10)
  durationMonths  Int?      @map("duration_months")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  createdBy       String    @map("created_by") @db.Uuid
  @@map("coupons")
}

model Charge {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  efiChargeId   String?       @map("efi_charge_id") @db.VarChar(100)
  efiSubscriptionId String?   @map("efi_subscription_id") @db.VarChar(100)
  amount        Decimal       @db.Decimal(10, 2)
  discountValue Decimal?      @map("discount_value") @db.Decimal(10, 2)
  dueDate       DateTime      @map("due_date") @db.Date
  paidAt        DateTime?     @map("paid_at")
  paymentMethod PaymentMethod @map("payment_method")
  status        ChargeStatus  @default(PENDING)
  referenceMonth String?      @map("reference_month") @db.VarChar(7)
  boletoUrl     String?       @map("boleto_url") @db.Text
  pixCopiaECola String?       @map("pix_copia_e_cola") @db.Text
  note          String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  @@map("charges")
}

model User {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid
  name            String          @db.VarChar(150)
  email           String          @db.VarChar(255)
  passwordHash    String          @map("password_hash") @db.VarChar(255)
  role            UserRole
  cpf             String?         @db.VarChar(14)
  birthday        DateTime?       @db.Date
  phone           String?         @db.VarChar(20)
  avatarUrl       String?         @map("avatar_url") @db.Text
  themePreference ThemePreference @default(DARK) @map("theme_preference")
  leadVisibility  VisibilityType  @default(OWN) @map("lead_visibility")
  isActive        Boolean         @default(true) @map("is_active")
  emailVerified   Boolean         @default(false) @map("email_verified")
  emailVerificationToken String?  @map("email_verification_token") @db.VarChar(100)
  passwordResetToken     String?  @map("password_reset_token") @db.VarChar(100)
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")
  userStatus      String          @default("ACTIVE") @map("user_status") @db.VarChar(20)
  rampingStartsAt DateTime?       @map("ramping_starts_at") @db.Date
  lastLoginAt     DateTime?       @map("last_login_at")
  firstLoginAt    DateTime?       @map("first_login_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  ledTeams        Team[]
  teamMemberships TeamMember[]
  assignedLeads   Lead[]          @relation("LeadResponsible")
  createdLeads    Lead[]          @relation("LeadCreatedBy")
  permissions     UserPermission[]
  oauthTokens     OAuthToken[]
  interactions    Interaction[]
  tasks           Task[]          @relation("TaskResponsible")
  // Tarefas criadas por este usuário. Backed by a real DB FK
  // (see migration add_created_by_relations) so every Task row
  // in the tenant is guaranteed to resolve to a real User.
  tasksCreated    Task[]          @relation("TaskCreatedBy")
  // Tarefas gerenciais criadas por este usuário. **Logical
  // relation only** — the `managerial_tasks.created_by` column
  // has no DB FK because SUPER_ADMIN writes an AdminUser id
  // (which lives in `admin_users`, not `users`). Prisma joins
  // still work for regular-tenant rows; SUPER_ADMIN rows resolve
  // createdByUser to null. Don't let `prisma migrate dev` turn
  // this into a real FK — that would break super-admin task
  // creation. Keep it logical.
  managerialTasksCreated ManagerialTask[] @relation("ManagerialTaskCreatedBy")
  notifications   Notification[]
  pipelineAccesses UserPipelineAccess[]
  pushSubscriptions PushSubscription[]
  apiKeysCreated    ApiKey[]           @relation("ApiKeyCreatedBy")
  webhooksCreated   WebhookEndpoint[]  @relation("WebhookEndpointCreatedBy")
  partnerChangesByUser TenantPartnerChange[] @relation("PartnerChangedByUser")
  @@unique([tenantId, email])
  @@map("users")
}

// Web Push subscriptions (Push API + Service Worker). Cada device do
// vendedor que aceitou notificações tem 1 linha aqui. O endpoint é
// gerado pelo navegador (único por device/origem). Em caso de 410 Gone
// no envio (subscription expirada), removemos a linha automaticamente.
//
// Eventos que disparam push (escolhidos com Lucas em 2026-05-03):
//   1. Lead atribuído ao vendedor responsável
//   2. Tarefa vencendo (cron checa a cada 5 min)
//   3. Desconto aguardando aprovação (notifica OWNER/MANAGER)
//
// Pra criar VAPID keys: npx web-push generate-vapid-keys (vai pra .env
// como VAPID_PUBLIC_KEY/VAPID_PRIVATE_KEY/VAPID_SUBJECT). Public key
// também precisa estar exposta como VITE_VAPID_PUBLIC_KEY no frontend.
model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, endpoint])
  @@map("push_subscriptions")
}

// API keys da v1 da API pública (uso externo: integração com landing
// page, sistema próprio do cliente, Zapier-like). Cada tenant pode
// criar múltiplas keys (uma por integração) via UI em
// /gestao/configuracoes/api. Apenas OWNER/MANAGER cria/revoga.
//
// Segurança:
//   - keyHash: hash SHA-256 da key real (nunca armazenamos texto plano).
//     Lookup no middleware apiKeyAuth: hash(headerKey) === keyHash.
//   - keyPrefix: primeiros 12 chars da key ("tcrm_live_abc"). Mostrado
//     na lista pra usuário identificar qual key é qual sem revelar a
//     completa. A key inteira só aparece UMA VEZ na criação.
//   - revokedAt: soft-delete. Lookup ignora keys com revokedAt != null.
//   - lastUsedAt: atualizado best-effort em cada request bem-sucedido
//     (sem bloquear o pipeline — fire-and-forget).
//
// FK Cascade: se o tenant é deletado, suas keys vão junto. createdBy
// usa SET NULL pra preservar a key se o user for removido (auditoria).
model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(100)
  keyHash     String    @unique @map("key_hash") @db.VarChar(64)
  keyPrefix   String    @map("key_prefix") @db.VarChar(20)
  lastUsedAt  DateTime? @map("last_used_at")
  revokedAt   DateTime? @map("revoked_at")
  createdBy   String?   @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator     User?     @relation("ApiKeyCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  @@index([tenantId])
  @@map("api_keys")
}

// Endpoint de webhook de saída cadastrado pelo tenant. Cada endpoint
// escuta um subset de eventos (events: array de strings tipo
// "lead.created", "lead.won" etc.). O secret é gerado uma vez na
// criação e usado pra HMAC SHA-256 do payload — cliente valida pra
// garantir que veio mesmo do TriboCRM.
//
// Limites: 10 endpoints ativos por tenant (gate no controller).
//
// FK Cascade pro tenant. createdBy SetNull (preserva endpoint mesmo
// se o user que criou for removido — auditoria).
model WebhookEndpoint {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(100)
  url         String    @db.Text
  // Secret em texto plano (não hashado) porque precisamos dele pra
  // assinar cada payload com HMAC. Cliente também tem cópia pra
  // validar a assinatura. Só dono do endpoint vê o secret na UI
  // (não aparece em listagens públicas — controller esconde).
  secret      String    @db.VarChar(80)
  events      String[]  // ex: ["lead.created", "lead.won"]
  isActive    Boolean   @default(true) @map("is_active")
  createdBy   String?   @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator     User?     @relation("WebhookEndpointCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  deliveries  WebhookDelivery[]
  @@index([tenantId])
  @@map("webhook_endpoints")
}

// Log de cada tentativa de entrega. Uma linha por endpoint+evento+attempt.
// Status: PENDING (na fila pra retry), SUCCESS (HTTP 2xx), FAILED (esgotou
// 3 tentativas ou recebeu 4xx que não é retryable).
//
// nextRetryAt: quando vai ser próxima tentativa. NULL se SUCCESS ou FAILED
// definitivo. Cron simples lê deliveries com status=PENDING e
// nextRetryAt <= now() pra reenviar.
//
// Retenção: 90 dias (job de limpeza apaga depois). Sem isso a tabela cresce
// indefinidamente.
model WebhookDelivery {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  endpointId      String   @map("endpoint_id") @db.Uuid
  eventType       String   @map("event_type") @db.VarChar(50)
  payload         Json
  status          String   @default("PENDING") @db.VarChar(20)
  attemptCount    Int      @default(0) @map("attempt_count")
  lastResponseStatus Int?  @map("last_response_status")
  lastResponseBody String? @map("last_response_body") @db.Text
  lastError       String?  @map("last_error") @db.Text
  nextRetryAt     DateTime? @map("next_retry_at")
  deliveredAt     DateTime? @map("delivered_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  endpoint        WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([status, nextRetryAt])
  @@map("webhook_deliveries")
}

// Programa de parceiros (afiliados/agências) — Super Admin cadastra
// agências que recebem comissão por indicação. Cada parceiro tem um
// código único usado em links de divulgação (?ref=CODIGO) e que
// clientes podem cadastrar manualmente na área do gestor.
//
// Comissão é recorrente (gerada a cada cobrança paga do cliente),
// vitalícia enquanto cliente estiver ativo + parceiro estiver ativo.
// Carência de 30 dias (D+30) antes de virar AVAILABLE — protege
// contra reembolsos. Após carência, sem reversão por cancelamento.
//
// Auto-indicação é bloqueada via comparação de document (CPF/CNPJ)
// e email do tenant com os do parceiro.
model Partner {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(150)
  email          String   @db.VarChar(255)
  document       String?  @db.VarChar(18)  // CNPJ ou CPF (digits-only)
  phone          String?  @db.VarChar(20)
  // Dados pra pagamento manual (sem integração bancária):
  // chave PIX preferida + dados bancários estruturados (4 campos)
  // + observações livres em bankInfo (compat retroativa, opcional).
  pixKey            String?  @map("pix_key") @db.VarChar(150)
  bankName          String?  @map("bank_name") @db.VarChar(100)
  bankBranch        String?  @map("bank_branch") @db.VarChar(20)
  bankAccount       String?  @map("bank_account") @db.VarChar(30)
  bankAccountType   String?  @map("bank_account_type") @db.VarChar(20)  // CHECKING | SAVINGS
  bankInfo          String?  @map("bank_info") @db.Text                  // observações livres (legacy)
  // Código único usado em ?ref= e cadastro manual. Gerado automático
  // (PRT + 8 chars hex). Indexado pra lookup rápido na API pública.
  code           String   @unique @db.VarChar(20)
  // DEPRECATED — mantido pra compat retroativa. Comissão agora é
  // calculada por commissionTiers (faixas progressivas). Coluna fica
  // como Decimal? (nullable) pra não exigir backfill em parceiros
  // antigos. Comissões já criadas congelam o rate aplicado.
  commissionRate  Decimal? @map("commission_rate") @db.Decimal(5, 2)
  // Tabela de comissão progressiva por faixa de clientes ativos.
  // Array JSON de até 3 tiers em ordem ASCENDENTE de maxClients:
  //   [
  //     { "maxClients": 5,    "rate": 15 },   // até 5 ativos: 15%
  //     { "maxClients": 19,   "rate": 20 },   // até 19 ativos: 20%
  //     { "maxClients": null, "rate": 25 }    // null = "acima do tier anterior"
  //   ]
  // Engine conta tenants ACTIVE referidos pelo parceiro NO MOMENTO da
  // cobrança virar PAID e aplica a faixa correta. Rate é congelado
  // na PartnerCommission criada — parceiro não perde retroativo se
  // cliente cancelar.
  commissionTiers Json     @default("[]") @map("commission_tiers")
  isActive       Boolean  @default(true) @map("is_active")
  notes          String?  @db.Text
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  // tenants indicados por esse parceiro (pode ser 0 ou N).
  referredTenants Tenant[] @relation("TenantReferredByPartner")
  commissions    PartnerCommission[]
  partnerChangesAsOld TenantPartnerChange[] @relation("PartnerChangeOldPartner")
  partnerChangesAsNew TenantPartnerChange[] @relation("PartnerChangeNewPartner")
  @@map("partners")
}

// Cada cobrança paga (Charge.status = PAID) que o tenant indicado
// gera cria UMA linha aqui. Status:
//   PENDING   — em carência (paidAt + 30d ainda no futuro)
//   AVAILABLE — saiu da carência, pronta pra ser paga ao parceiro
//   PAID      — Super Admin marcou como pago (controle financeiro)
//   REVERSED  — caso raro: reembolso/chargeback dentro da carência
//
// availableAt = chargePaidAt + 30 dias. Cron diário promove de
// PENDING → AVAILABLE quando o relógio passa.
//
// rate é congelado no momento da criação (parceiro pode mudar % no
// futuro — comissões antigas mantêm o valor original).
model PartnerCommission {
  id          String   @id @default(uuid()) @db.Uuid
  partnerId   String   @map("partner_id") @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  chargeId    String   @unique @map("charge_id") @db.Uuid
  amount      Decimal  @db.Decimal(12, 2)
  rate        Decimal  @db.Decimal(5, 2)
  commission  Decimal  @db.Decimal(12, 2)
  status      String   @default("PENDING") @db.VarChar(20)
  availableAt DateTime @map("available_at")
  paidAt      DateTime? @map("paid_at")
  reversedAt  DateTime? @map("reversed_at")
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  partner     Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation("CommissionsForTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  @@index([partnerId, status])
  @@index([status, availableAt])
  @@index([tenantId])
  @@map("partner_commissions")
}

// Histórico de troca de parceiro pelo tenant. Útil pra auditoria e
// suporte ("por que parceiro X reclama de não receber comissão de
// fevereiro? Cliente trocou em 28/jan."). Incluí oldPartnerId NULL
// pro registro inicial do vínculo (signup ou primeiro cadastro).
model TenantPartnerChange {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  oldPartnerId  String?  @map("old_partner_id") @db.Uuid
  newPartnerId  String?  @map("new_partner_id") @db.Uuid
  changedBy     String?  @map("changed_by") @db.Uuid
  source        String   @db.VarChar(30)  // signup_cookie | gestor_ui | super_admin
  createdAt     DateTime @default(now()) @map("created_at")
  tenant        Tenant   @relation("PartnerChangesForTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  oldPartner    Partner? @relation("PartnerChangeOldPartner", fields: [oldPartnerId], references: [id], onDelete: SetNull)
  newPartner    Partner? @relation("PartnerChangeNewPartner", fields: [newPartnerId], references: [id], onDelete: SetNull)
  changedByUser User?    @relation("PartnerChangedByUser", fields: [changedBy], references: [id], onDelete: SetNull)
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("tenant_partner_changes")
}

// Acesso de usuario a pipelines do tenant. Many-to-many entre User e
