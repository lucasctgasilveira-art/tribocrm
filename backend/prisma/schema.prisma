  visibleFor String[]         @default(["SELLER", "TEAM_LEADER", "MANAGER", "OWNER"]) @map("visible_for")
  sortOrder  Int              @map("sort_order")
  createdAt  DateTime         @default(now()) @map("created_at")
  tasks      ManagerialTask[]
  @@map("managerial_task_types")
}

model ManagerialTask {
  id                 String                      @id @default(uuid()) @db.Uuid
  tenantId           String                      @map("tenant_id") @db.Uuid
  typeId             String                      @map("type_id") @db.Uuid
  createdBy          String                      @map("created_by") @db.Uuid
  title              String                      @db.VarChar(200)
  description        String?                     @db.Text
  dueDate            DateTime?                   @map("due_date")
  isRecurring        Boolean                     @default(false) @map("is_recurring")
  recurrence         RecurrenceType?
  recurrenceOriginId String?                     @map("recurrence_origin_id") @db.Uuid
  isDone             Boolean                     @default(false) @map("is_done")
  doneAt             DateTime?                   @map("done_at")
  createdAt          DateTime                    @default(now()) @map("created_at")
  taskType           ManagerialTaskType          @relation(fields: [typeId], references: [id])
  participants       ManagerialTaskParticipant[]
  // **Logical relation only** — no DB FK. SUPER_ADMIN writes
  // an AdminUser id into `created_by`, which doesn't exist in
  // users, so a real FK would break that path. Prisma joins
  // still work: regular-tenant rows resolve the creator, super
  // admin rows return null for createdByUser. See the matching
  // migration note and keep it this way.
  createdByUser      User                        @relation("ManagerialTaskCreatedBy", fields: [createdBy], references: [id])
  @@map("managerial_tasks")
}

model ManagerialTaskParticipant {
  id         String         @id @default(uuid()) @db.Uuid
  taskId     String         @map("task_id") @db.Uuid
  userId     String         @map("user_id") @db.Uuid
  notifiedAt DateTime?      @map("notified_at")
  task       ManagerialTask @relation(fields: [taskId], references: [id])
  @@unique([taskId, userId])
  @@map("managerial_task_participants")
}

