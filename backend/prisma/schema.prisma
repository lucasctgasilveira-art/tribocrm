model Task {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  leadId        String    @map("lead_id") @db.Uuid
  responsibleId String    @map("responsible_id") @db.Uuid
  createdBy     String    @map("created_by") @db.Uuid
  type          TaskType
  title         String    @db.VarChar(200)
  description   String?   @db.Text
  dueDate       DateTime? @map("due_date")
  isDone        Boolean   @default(false) @map("is_done")
  doneAt        DateTime? @map("done_at")
  // Campos pra agendamento de mensagem WhatsApp via Tarefa.
  // Quando type='WHATSAPP' + dueDate + (whatsappTemplateId OU
  // whatsappMessageBody), backend marca sendStatus='PENDING' e a
  // extensao Chrome envia automaticamente no horario agendado.
  // Tarefas-lembrete normais tem todos esses campos NULL.
  whatsappTemplateId  String?           @map("whatsapp_template_id") @db.Uuid
  whatsappMessageBody String?           @map("whatsapp_message_body") @db.Text
  sendStatus          String?           @map("send_status") @db.VarChar(20)
  sentAt              DateTime?         @map("sent_at")
  sendError           String?           @map("send_error") @db.Text
  reminderMinutes     Int?              @map("reminder_minutes")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lead          Lead      @relation(fields: [leadId], references: [id])
  responsible   User      @relation("TaskResponsible", fields: [responsibleId], references: [id])
  // Real DB FK — all Task.createdBy values come from
  // req.user.userId (regular users) or lead.responsibleId
  // (automation), both guaranteed to exist in users.
  createdByUser User      @relation("TaskCreatedBy", fields: [createdBy], references: [id])
  whatsappTemplate WhatsappTemplate? @relation(fields: [whatsappTemplateId], references: [id])
  @@index([sendStatus, dueDate])
  @@map("tasks")
}

