// Persistent record of every time a lead was closed as WON. The
// existing Lead row carries only the latest closedValue/wonAt — we
// append a row here every time status flips to WON so the drawer can
// render a real "Histórico de compras" with all past sales preserved.
// See leads.controller.updateLead for the write site and
// GET /leads/:id/purchases for the read side.
model LeadPurchase {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  leadId      String   @map("lead_id") @db.Uuid
  closedValue Decimal  @map("closed_value") @db.Decimal(12, 2)
  wonAt       DateTime @map("won_at")
  productName String?  @map("product_name")
  closedBy    String?  @map("closed_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  lead        Lead     @relation(fields: [leadId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  @@map("lead_purchases")
}

model LeadProduct {
